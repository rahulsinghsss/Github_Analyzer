{
  "info": {
    "name": "GitHub Profile Analyzer API",
    "description": "API collection for the GitHub Profile Analyzer. Includes endpoints for fetching and analyzing profiles.\n\nUse the `baseUrl` collection variable to switch between local and production environments:\n- Local: `http://localhost:3000`\n- Production: `https://github-analyzer-beta-beryl.vercel.app`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Analyze Profile",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"rahulsinghsss\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/profiles/analyze",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "profiles",
            "analyze"
          ]
        }
      }
    },
    {
      "name": "Get All Profiles",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/profiles",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "profiles"
          ]
        }
      }
    },
    {
      "name": "Get Profile By Username",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/profiles/rahulsinghsss",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "profiles",
            "rahulsinghsss"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://github-analyzer-beta-beryl.vercel.app",
      "type": "string"
    }
  ]
}
